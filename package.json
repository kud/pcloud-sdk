{
  "name": "@kud/pcloud-sdk",
  "version": "0.1.0",
  "description": "Typed pCloud API client — shared SDK for CLI, MCP, and extensions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "pcloud",
    "api",
    "sdk",
    "typescript"
  ],
  "author": "kud",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kud/pcloud-sdk.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^6.0.0"
  }
}
